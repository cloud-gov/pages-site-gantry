---
import { getCollection, type CollectionEntry } from "astro:content";
import GovIdentifier from "@/components/GovIdentifier.astro";
import Menu from "@/components/Menu.astro";
import Breadcrumb from "@/components/Breadcrumb.astro";
import Footer from "@/components/Footer.astro";
import Config from "@/config.astro";
import { getMediaUrl } from "@/utilities/media";
import "@theme";
import DigitalAnalytics from "@/components/DigitalAnalytics.astro";
import PreviewReload from "@/components/PreviewReload.astro";
import {
  fetchSiteConfig,
  fetchMenu,
  fetchPreFooter,
  fetchCollection,
  alertsMapper,
  fetchCollectionEntry,
  buildMenuWithCollectionSlugs,
  fetchFooter,
  footerMapper,
} from "@/utilities/fetch";
import Alerts from "@/components/Alerts.astro";
import FiltersSlugMetaData from "@/components/FiltersSlugMetaData.astro";
import type {
  FiltersSlugMetaDataModel,
  AlertModel,
  FooterModel,
  MenuRoot,
} from "@/env";
import { buildPreFooterWithCollectionSlugs } from "@/utilities/fetch/buildMenuWithCollectionSlugs";
import type { DataEntryMap } from "astro:content";

const siteConfigCollectionName = "siteConfig";
const menuCollectionName = "menu";
const footerCollectionName = "footer";
const preFooterCollectionName = "preFooter";
const alertsCollectionName = "alerts";

/** Helpers */
async function getFirstData<TName extends keyof DataEntryMap>(name: TName) {
  // getCollection returns Array<CollectionEntry<TName>>
  const items = await getCollection(name);
  return items?.[0]?.data;
}

function ensureMenuShape(raw: Partial<MenuRoot> | undefined): MenuRoot {
  return {
    id: raw?.id ?? "menu",
    items: raw?.items ?? [],
    ...raw,
  } as MenuRoot;
}

/** Unified data loader producing a single, consistent shape */
async function loadData() {
  if (!Astro.isPrerendered) {
    // Runtime branch: use remote fetchers
    const [siteConfigRaw, menuRaw, footerRaw, preFooterRaw, alertsRaw] =
      await Promise.all([
        fetchSiteConfig(),
        fetchMenu(),
        fetchFooter(),
        fetchPreFooter(),
        fetchCollection(alertsCollectionName),
      ]);

    const menuBase = ensureMenuShape(menuRaw);
    const [collectionsMenu, preFooterWithSlugs] = await Promise.all([
      buildMenuWithCollectionSlugs(menuBase, fetchCollectionEntry),
      buildPreFooterWithCollectionSlugs(preFooterRaw, fetchCollectionEntry),
    ]);

    const alerts = alertsMapper(alertsRaw?.docs);

    return {
      siteConfig: {
        agencyName: siteConfigRaw?.agencyName ?? "Agency Homepage",
        searchAccessKey: siteConfigRaw?.searchAccessKey,
        searchAffiliate: siteConfigRaw?.searchAffiliate,
        dapAgencyCode: siteConfigRaw?.dapAgencyCode,
        dapSubAgencyCode: siteConfigRaw?.dapSubAgencyCode,
      },
      menu: menuBase,
      collectionsMenu,
      footerCollectionResponse: footerRaw,
      preFooterCollectionResponse: preFooterWithSlugs,
      alerts,
    };
  } else {
    // Prerendered branch: use local content
    const [
      siteConfigData,
      menuEntries,
      footerData,
      preFooterData,
      alertsEntries,
    ] = await Promise.all([
      getFirstData<typeof siteConfigCollectionName>(siteConfigCollectionName),
      getCollection(menuCollectionName),
      getFirstData<typeof footerCollectionName>(footerCollectionName),
      getFirstData<typeof preFooterCollectionName>(preFooterCollectionName),
      getCollection(alertsCollectionName),
    ]);

    const menuBase = ensureMenuShape({
      id: menuEntries?.[0]?.id ?? "menu",
      items: menuEntries?.[0]?.data?.items ?? [],
    });

    const [collectionsMenu, preFooterWithSlugs, footerWithSlugs] =
      await Promise.all([
        buildMenuWithCollectionSlugs(menuBase, fetchCollectionEntry),
        buildPreFooterWithCollectionSlugs(preFooterData, fetchCollectionEntry),
        buildMenuWithCollectionSlugs(footerData, fetchCollectionEntry),
      ]);

    const alerts: AlertModel[] = alertsMapper(alertsEntries, true);

    return {
      siteConfig: {
        agencyName: siteConfigData?.agencyName ?? "Agency Homepage",
        searchAccessKey: siteConfigData?.searchAccessKey,
        searchAffiliate: siteConfigData?.searchAffiliate,
        dapAgencyCode: siteConfigData?.dapAgencyCode,
        dapSubAgencyCode: siteConfigData?.dapSubAgencyCode,
      },
      menu: menuBase,
      collectionsMenu,
      footerCollectionResponse: footerWithSlugs,
      preFooterCollectionResponse: preFooterWithSlugs,
      alerts,
    };
  }
}

const {
  siteConfig,
  menu,
  collectionsMenu,
  footerCollectionResponse,
  preFooterCollectionResponse,
  alerts,
} = await loadData();

const footer: FooterModel = footerMapper(
  footerCollectionResponse,
  preFooterCollectionResponse,
);

interface Props {
  title?: string;
  description?: string;
  socialImage?: any;
  canonical?: string;
  useInPageNav?: boolean;
  currentPage?: number;
  totalPages?: number;
  useBreadcrumbTitle?: boolean;
  filtersSlugMetaData?: FiltersSlugMetaDataModel;
}

// TODO: Add meta title and description to site config
const {
  title,
  description,
  socialImage,
  canonical,
  useInPageNav = false,
  currentPage,
  totalPages,
  filtersSlugMetaData,
  useBreadcrumbTitle = false,
} = Astro.props;

const metaTitle = title
  ? `${title} | ${siteConfig.agencyName ?? "Agency Homepage"}`
  : (siteConfig.agencyName ?? "Agency Homepage");

// Get proper URL for social image
const socialImageUrl = socialImage ? getMediaUrl(socialImage) : null;
const isHome = Astro.url.pathname === "/";
---

<!doctype html>
<html lang="en">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width" />
    <link rel="icon" type="image/svg+xml" href="/favicon.svg" />
    <title>{metaTitle}</title>
    {description && <meta name="description" content={description} />}
    {canonical && <link rel="canonical" href={canonical} />}
    <!-- Open Graph / Facebook -->
    <meta property="og:type" content="website" />
    <meta property="og:title" content={metaTitle} />
    {description && <meta property="og:description" content={description} />}
    {socialImageUrl && <meta property="og:image" content={socialImageUrl} />}
    <!-- Twitter -->
    <meta name="twitter:card" content="summary_large_image" />
    <meta name="twitter:title" content={metaTitle} />
    {description && <meta name="twitter:description" content={description} />}
    {socialImageUrl && <meta name="twitter:image" content={socialImageUrl} />}
    <link rel="preconnect" href="https://fonts.googleapis.com" />
    <link
      rel="preconnect"
      href="https://fonts.gstatic.com"
      crossorigin="anonymous"
    />
    <link
      href="https://fonts.googleapis.com/css2?family=Inter:ital,wght@0,400;0,500;0,600;0,700;1,400;1,500;1,600;1,700&family=Playfair+Display:ital,wght@0,400;0,500;0,600;0,700;0,900;1,400;1,500;1,600;1,700;1,900&display=swap"
      rel="stylesheet"
    />
    <FiltersSlugMetaData filtersSlugMetaData={filtersSlugMetaData} />
  </head>
  <body>
    <Config />
    <GovIdentifier />
    <Alerts alertsData={alerts} />
    <Menu
      title={siteConfig.agencyName}
      items={collectionsMenu?.items ?? []}
      searchAccessKey={siteConfig?.searchAccessKey}
      searchAffiliate={siteConfig.searchAffiliate}
    />
    <Breadcrumb
      currentPage={currentPage}
      totalPages={totalPages}
      breadcrumbTitle={useBreadcrumbTitle ? title : null}
    />
    <main
      id="main-content"
      class:list={{
        home: isHome,
      }}
    >
      <slot />
    </main>
    <Footer footer={footer} />
    {
      siteConfig.dapAgencyCode && (
        <DigitalAnalytics
          dapAgencyCode={siteConfig.dapAgencyCode}
          dapSubAgencyCode={siteConfig.dapSubAgencyCode}
        />
      )
    }
  </body><PreviewReload />
  <style>
    .usa-in-page-nav-container {
      position: relative;
      max-width: 75rem;
      margin-left: auto;
      margin-right: auto;
    }
    @media (min-width: 1024px) {
      .usa-in-page-nav {
        position: sticky;
        top: 2rem;
        right: calc(50% - 32rem - 1rem);
      }
    }
    @media (max-width: 1023px) {
      .usa-in-page-nav {
        display: none;
      }
    }
  </style>
  <script>
    import "@uswds/uswds";
  </script>
</html>
