---
import { join } from "node:path";
interface Props {
  href: string;
  className?: string;
  title?: string;
}

const { href, className = "usa-link", title } = Astro.props;

// do not prepend base for external links
const externalRegex = /https?:\/\//;
const base = externalRegex.test(href) ? "" : import.meta.env.BASE_URL;
---

<a
  href={base.length > 0 ? join(base, href) : href}
  class={className}
  title={title}
>
  <slot />
</a>
