---
import CollectionItem from "./CollectionItem.astro";
import type { FiltersSlugMetaDataModel } from "../env";

interface Props {
  item: any;
  filtersSlugMetaData: FiltersSlugMetaDataModel;
  showEvent: boolean;
  layoutType?: "grid" | "list";
}

const {
  item,
  filtersSlugMetaData,
  layoutType,
  showEvent = false,
} = Astro.props;
---

{
  filtersSlugMetaData && (
    <template id={filtersSlugMetaData.collectionItemId}>
      <>
        <CollectionItem {...item} itemType={layoutType} showEvent={showEvent} />
      </>
    </template>
  )
}
