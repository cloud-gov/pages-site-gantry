---
import { type FiltersConfig } from "@/utilities/filtersConfig";

interface Props {
  filter: FiltersConfig;
}
const { filter } = Astro.props;
const { filterName, filterLabel } = filter;
---

<!-- WARNING: The nav element's ID is used to show or hide the filter based on its content.
Changing the nav element's ID may break the filter toggle. -->

<nav
  class="usa-sidenav"
  aria-label=`Filter ${filterName}`
  id=`nav-${filterName}`
>
  <label class="usa-label" for={filterName}>{filterLabel}</label>
  <div class="usa-combo-box">
    <select class="usa-select" name={filterName} id={filterName}> </select>
  </div>
</nav>

<style is:global>
  .usa-combo-box__list {
    overflow-y: auto !important;
  }
</style>
