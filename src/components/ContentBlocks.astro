---
import payloadFetch from "../utilities/payload-fetch";
import Hero from "./Hero.astro";
import CardGrid from "./CardGrid.astro";
import RichText from "./RichText.astro";

// Fetch home page data from Payload CMS
let homePageData: any = null;

try {
  const response = await payloadFetch("globals/home-page");
  if (response.ok) {
    homePageData = await response.json();
  }
} catch (error) {
  console.warn("Could not fetch home page data from API:", error);
}

const contentBlocks = homePageData?.content || [];
---

{contentBlocks.map((block: any, index: number) => {
  switch (block.blockType) {
    case 'hero':
      return <Hero 
        title={block.title}
        subtitle={block.subtitle}
        description={block.description}
        bgImage={block.bgImage}
        ctaButton={block.ctaButton}
      />;
    
    case 'cardGrid':
      return (
        <CardGrid 
          title={block.title}
          cards={block.cards?.map((card: any) => ({
            title: card.title,
            description: card.description,
            image: card.image,
            ctaText: card.link?.text,
            ctaURL: card.link?.url
          })) || []}
        />
      );
    
    case 'textBlock':
      return (
        <section class={`usa-section bg-${block.bgColor || 'white'}`}>
          <div class="grid-container">
            <div class="maxw-4xl">
              {block.title && (
                <h2 class="font-heading-xl margin-bottom-3">{block.title}</h2>
              )}
              {block.content && (
                <RichText content={block.content} />
              )}
            </div>
          </div>
        </section>
      );
    
    default:
      return null;
  }
})}
