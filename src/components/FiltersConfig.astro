---
import type { CollectionFiltersConfig } from "@/env";

interface Props {
  collectionFiltersConfig?: CollectionFiltersConfig;
}

const { collectionFiltersConfig } = Astro.props;
---

{
  collectionFiltersConfig?.filters?.map(
    (filter) =>
      filter && (
        <meta
          data-pagefind-filter={filter?.atrributeValue}
          content={filter?.content}
        />
      ),
  )
}
