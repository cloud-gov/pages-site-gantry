---
import Filter from "./Filter.astro";
import { FILTERS_CONFIG, FILTERS_DATA_ID } from "@/utilities/filtersConfig";
import { getFiltersDataAttributes } from "@/utilities/filters";
import type { FilteredPageConfig } from "@/env";

interface Props {
  filteredPageConfig: FilteredPageConfig;
}

const { filteredPageConfig } = Astro.props;

const baseUrl = import.meta.env.LOCAL_DEV
  ? "/"
  : (import.meta.env.BASEURL || "") + "/";

const dataAttributes = getFiltersDataAttributes(
  FILTERS_CONFIG,
  filteredPageConfig,
  baseUrl,
);
---

<aside class="sidenav-container">
  {
    dataAttributes && (
      <span id={FILTERS_DATA_ID} {...dataAttributes} style="display:none" />
    )
  }
  {FILTERS_CONFIG?.map((filter) => <Filter filter={filter} />)}
</aside>

<script>
  import {
    getFiltersData,
    getFiltersFromQueryParams,
    displayFilters,
    createFilteredCollectionItemList,
    createFilteredPagination,
    getSearchOptions,
    search,
    addFiltersEventListeners,
    addPaginationEventListeners,
    buildSearchOptions,
    resetFilteredPage,
  } from "../utilities/filters";
  import { type ElementsPair, type FiltersData } from "../env.d";

  try {
    const data: FiltersData = getFiltersData();
    if (data) {
      const pagefind = await import(data.baseUrl + "pagefind/pagefind.js");
      pagefind.init();
      const pagefindFilters = await pagefind.filters();

      const filtersFromQueryParams = getFiltersFromQueryParams(window);

      const displayedFilters: boolean = displayFilters(
        data.filtersMap,
        filtersFromQueryParams,
        pagefindFilters,
      );

      if (displayedFilters) {
        const collectionList: ElementsPair = createFilteredCollectionItemList();
        const pagination: ElementsPair = createFilteredPagination();

        addFiltersEventListeners(data.filtersMap, async function () {
          if (data.currentPageNum !== "1") {
            resetFilteredPage();
          } else {
            await search(
              pagefind,
              getSearchOptions(data.filtersMap),
              collectionList,
              pagination,
              data,
            );
          }
        });
        addPaginationEventListeners(pagination, data);

        if (filtersFromQueryParams?.size > 0) {
          await search(
            pagefind,
            buildSearchOptions(data.collectionName, filtersFromQueryParams),
            collectionList,
            pagination,
            data,
          );
        }
      }
    }
  } catch (err) {
    console.error("Pagefind not available:", err);
  }
</script>
