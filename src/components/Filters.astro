---
import Filter from "./Filter.astro";
import { filtersConfig } from "@/utilities/filtersConfig";
import { getFiltersDataAttributes } from "@/utilities/filters";

interface Props {
  collectionName: string;
}

const { collectionName = "" } = Astro.props;

const baseUrl = import.meta.env.LOCAL_DEV
  ? "/"
  : (import.meta.env.BASEURL || "") + "/";

const filtersDataAttributes = getFiltersDataAttributes(
  filtersConfig,
  collectionName,
);
---

<aside class="sidenav-container">
  <span
    id="pagefind-data"
    data-baseurl={baseUrl}
    {...filtersDataAttributes}
    style="display:none"></span>

  {filtersConfig?.map((filter) => <Filter filter={filter} />)}

  <div id="results-count"></div>
  <div id="recommended"></div>
  <div id="search-results"></div>
  <hr class="margin-bottom-3 margin-top-3" />
  <div id="pagination"></div>
</aside>
<script>
  import {
    addFilters,
    getSearchOptions,
    extractCollectionFilters,
    getElement,
    getFiltersFromElementData,
  } from "../utilities/filters.ts";

  const pagefindDataElement = document.getElementById("pagefind-data");
  const baseUrl = pagefindDataElement?.dataset.baseurl;

  const filtersMap = getFiltersFromElementData(pagefindDataElement);
  console.log(filtersMap);

  const pagefind = await import(baseUrl + "pagefind/pagefind.js");
  pagefind.init();
  const pagefindFilters = await pagefind.filters();

  Object.keys(filtersMap).forEach((filterKey) => {
    const { filterName, pagefindfilter } = filtersMap[filterKey];
    const el = getElement(filterName); // get DOM element
    const navEl = document.getElementById("nav-" + filterName); // get DOM element

    if (el) {
      // Add the element to the map entry
      filtersMap[filterKey].filterElement = el;
      filtersMap[filterKey].navElement = navEl;

      // Apply the filter
      addFilters(
         extractCollectionFilters(pagefindFilters, pagefindfilter),
        el,
        navEl,
      );
    }
  });

  const resultsDiv = document.getElementById("search-results");

  function renderResults(results) {
    if (!results || results.length === 0) {
      resultsDiv.innerHTML = "<p>No results found.</p>";
      return;
    }

    const urls = results
      .map((obj) => {
        return obj?.url;
      })
      .filter(Boolean); // remove undefined

    resultsDiv.innerHTML = urls
      .map((url) => `<div><a href="${url}" target="_blank">${url}</a></div>`)
      .join("");
  }

  // Function to call when either dropdown changes
  async function handleFilterChange() {
    const searchOptions = getSearchOptions(filtersMap);
    let results = [];
    if (searchOptions) {
      const searchResults = await pagefind.search(null, searchOptions);
      results = await Promise.all(searchResults.results.map((r) => r.data()));
    }
    renderResults(results);
  }

  Object.keys(filtersMap).forEach((filterKey) => {
    const { filterName, pagefindfilter, filterElement } = filtersMap[filterKey];
    const el = getElement(filterName); // get DOM element

    if (filterElement) {
      filterElement.addEventListener("change", handleFilterChange);
    }
  });
</script>

<style is:global>
  .usa-sidenav {
    position: sticky;
    top: 0;
    height: fit-content;
    max-height: calc(100vh - 2rem);
  }

  .usa-sidenav__list {
    list-style: none;
    margin: 0;
    padding: 0;
  }

  .usa-sidenav__item {
    margin: 0;
  }

  /* Dropdown parent styling - looks like link but not clickable */
  .usa-sidenav__item > span.usa-sidenav__link {
    cursor: default;
    display: block;
    padding: 0.5rem 1rem;
    text-decoration: none;
  }

  /* Hide side navigation on mobile */
  @media (max-width: 768px) {
    .usa-sidenav {
      display: none;
    }
  }
</style>
