---
import type { FilteredPageConfig } from "@/env";
import Filters from "./Filters.astro";

interface Props {
  heading?: string;
  subheading?: string;
  classes?: string;
  id?: string;
  color?: string;
  align?: "center" | "left";
  filteredPageConfig?: FilteredPageConfig;
}

const {
  heading = false,
  subheading = false,
  color = "white",
  align = "left",
  classes = "",
  id = false,
  filteredPageConfig,
} = Astro.props;
---

<section
  {...id && { id }}
  class={`usa-section section section--${color} align-${align} ${classes}`}
>
  <div class="grid-container">
    <div class="section__container">
      <div class="section__intro">
        {
          heading && (
            <div class="grid-container">
              <h1>{heading}</h1>
              {subheading && (
                <p class="usa-intro font-md margin-top-2 margin-bottom-1">
                  {subheading}
                </p>
              )}
            </div>
          )
        }
      </div>
    </div>
    <section class="grid-container usa-section">
      <div
        class=`grid-row grid-gap ${filteredPageConfig ? "sidebar-layout" : ""}`
      >
        <div class="sidebar-layout__sidebar">
          {
            filteredPageConfig && (
              <div class="filter-sidebar">
                <Filters filteredPageConfig={filteredPageConfig} />
              </div>
            )
          }
          <div class="grid-row margin-left-1">
            <slot name="sidebar" />
          </div>
        </div>
        <div class="sidebar-layout__main">
          <div class="section__container">
            <div class="section__slot">
              <slot />
            </div>
          </div>
        </div>
      </div>
    </section>
  </div>
</section>

<style>
  /* Remove top padding from usa-section */
  section {
    padding-top: 2rem;
  }

  &.align-left .section__container {
    text-align: left;
    justify-items: start;
  }

  &.align-center .section__container {
    .section__intro,
    .section__content,
    .section__slot,
    .section__outro {
      margin-left: auto;
      margin-right: auto;
      text-align: center;
      justify-items: center;
    }
  }
  .section__slot {
    padding: 1rem 0;
  }

  @media (max-width: 1023px) {
    .sidebar-section {
      order: -1;
    }
    .main-section,
    .sidebar-section {
      flex: 0 0 100%;
      max-width: 100%;
    }
  }

  @media (max-width: 480px) {
    .grid-row.grid-gap {
      display: block;
    }
  }
</style>
