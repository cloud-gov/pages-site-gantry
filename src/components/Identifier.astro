---
import { type IdentifierModel } from "@/env.d";
import RichText from "@/components/RichText.astro";
import { getMediaUrl } from "@/utilities/media.ts";

interface Props {
  identifier?: IdentifierModel;
}
const { identifier } = Astro.props;
const siteDomain = identifier?.siteDomain;
const links = identifier?.links;
const logos = identifier?.logos;
const content = identifier?.content;

const richTextIdentifier = {
  textColor: "--color-primary-on",
  linkColor: "--color-primary-on",
};
const baseUrl = import.meta.env.BASEURL || "";
const cleanBaseUrl = baseUrl === "/" ? "" : baseUrl;
---

<div class="usa-identifier site-identifier">
  <section
    class="usa-identifier__section usa-identifier__section--masthead"
    aria-label="Agency identifier"
  >
    <div class="usa-identifier__container">
      {
        logos &&
          logos.map((logo) => (
            <div class="usa-identifier__logos">
              <a
                href={logo?.url}
                class="usa-identifier__logo usa-identifier__required-link"
              >
                <img
                  src={getMediaUrl(logo?.media)}
                  class="usa-identifier__logo-img"
                  alt={logo?.media?.altText}
                  loading="lazy"
                  decoding="async"
                />
              </a>
            </div>
          ))
      }
      <section class="usa-identifier__identity" aria-label="Agency description">
        <p class="usa-identifier__identity-domain">
          {siteDomain}
        </p>
        <p class="usa-identifier__identity-disclaimer">
          {
            content && (
              <RichText content={content} identifier={richTextIdentifier} />
            )
          }
        </p>
      </section>
    </div>
    <nav
      class="usa-identifier__section usa-identifier__section--required-links"
      aria-label="Important links"
    >
      <div class="usa-identifier__container">
        <ul class="usa-identifier__required-links-list">
          {
            links &&
              links.map((link) => (
                <li class="usa-identifier__required-links-item">
                  <a
                    href={cleanBaseUrl + link.url}
                    class={`usa-identifier__required-link usa-link${link.externalLink ? " usa-link--external" : ""}`}
                  >
                    {link.text}
                  </a>
                </li>
              ))
          }
        </ul>
      </div>
    </nav>
    <section
      class="usa-identifier__section usa-identifier__section--usagov"
      aria-label="Government information and services"
    >
      <div class="usa-identifier__container">
        <div class="usa-identifier__usagov-description">
          Looking for U.S. government information and services?
        </div>
        <a href="https://www.usa.gov/" class="usa-link--external"
          >&nbsp;Visit USA.gov</a
        >
      </div>
    </section>
  </section>
</div>

<style>
  .site-identifier,
  .site-identifier .usa-identifier__section--masthead,
  .site-identifier .usa-identifier__section--required-links {
    background-color: var(--color-primary);
    color: var(--color-primary-on);
  }

  .site-identifier .usa-identifier__identity-domain,
  .site-identifier .usa-identifier__required-link,
  .site-identifier .usa-identifier__required-link:visited,
  .site-identifier .usa-identifier__section--masthead a,
  .site-identifier .usa-identifier__section--masthead a:visited {
    color: var(--color-primary-on);
  }

  .site-identifier .usa-identifier__section--usagov {
    background-color: var(--color-surface);
    color: var(--color-text);
  }

  .site-identifier .usa-identifier__section--usagov a,
  .site-identifier .usa-identifier__section--usagov a:visited {
    color: var(--color-link);
  }
</style>
